---
import { SITE_TITLE } from '../consts';

const today = new Date();
---

<footer class="bg-black border-t border-white/10">
	<div class="mx-auto max-w-7xl px-6 py-12">
		<div class="grid grid-cols-1 md:grid-cols-12 gap-8">
			<div class="md:col-span-4 lg:col-span-5">
				<a href="/" class="group inline-flex items-center gap-2" aria-label={`${SITE_TITLE} Home`}>
					<span class="h-2.5 w-2.5 rounded-full bg-gradient-to-b from-cyan-400 to-blue-500 shadow-[0_0_20px_rgba(34,211,238,0.35)]" />
					<span class="text-sm font-medium tracking-tighter text-white/95 group-hover:text-white transition-colors">
						{SITE_TITLE}
					</span>
				</a>
				<p class="mt-3 text-neutral-400 text-sm leading-relaxed max-w-md">
					Advanced Resin 3D Printing • AI Workflows for Creators • Tech Hardware.
					Content designed for speed, clarity, and AdSense-friendly layout.
				</p>
			</div>

			<div class="md:col-span-2 lg:col-span-2">
				<p class="text-xs text-white/70 tracking-tight font-semibold uppercase">Company</p>
				<ul class="mt-4 space-y-3">
					<li>
						<a href="/about" class="text-sm text-neutral-400 hover:text-white transition-colors">About Us</a>
					</li>
					<li>
						<a href="/contact" class="text-sm text-neutral-400 hover:text-white transition-colors">Contact</a>
					</li>
					<li>
						<a href="/blog" class="text-sm text-neutral-400 hover:text-white transition-colors">Blog</a>
					</li>
				</ul>
			</div>

			<div class="md:col-span-2 lg:col-span-2">
				<p class="text-xs text-white/70 tracking-tight font-semibold uppercase">Legal</p>
				<ul class="mt-4 space-y-3">
					<li>
						<a href="/privacy" class="text-sm text-neutral-400 hover:text-white transition-colors">Privacy Policy</a>
					</li>
					<li>
						<a href="/terms" class="text-sm text-neutral-400 hover:text-white transition-colors">Terms of Service</a>
					</li>
				</ul>
			</div>
		</div>

		<div class="mt-10 border-t border-white/10 pt-8 flex items-center justify-between">
			<p class="text-xs text-neutral-500">
				&copy; {today.getFullYear()} {SITE_TITLE}. All rights reserved.
			</p>
			<div class="text-xs text-neutral-500">AdSense-ready links (dummy).</div>
		</div>
	</div>
</footer>

