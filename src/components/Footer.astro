---
import { SITE_TITLE } from '../consts';

const today = new Date();
---

<footer class="mt-auto border-t border-slate-200 bg-white">
	<div class="mx-auto max-w-6xl px-6 py-12">
		<div class="grid grid-cols-1 gap-10 md:grid-cols-12">
			<div class="md:col-span-5">
				<a href="/" class="group inline-flex items-center gap-2.5">
					<span class="flex h-8 w-8 items-center justify-center rounded-lg bg-blue-600 text-xs font-bold text-white">
						NG
					</span>
					<span class="text-sm font-semibold text-slate-900">{SITE_TITLE}</span>
				</a>
				<p class="mt-4 max-w-sm text-sm leading-relaxed text-slate-500">
					A modern tech magazine covering resin 3D printing, AI workflows, and hardware for makers and builders.
				</p>
			</div>

			<div class="md:col-span-3">
				<p class="text-xs font-semibold uppercase tracking-wider text-slate-400">Explore</p>
				<ul class="mt-4 space-y-3">
					<li><a href="/" class="text-sm text-slate-600 transition-colors hover:text-blue-600">Home</a></li>
					<li><a href="/blog" class="text-sm text-slate-600 transition-colors hover:text-blue-600">Blog</a></li>
					<li><a href="/about" class="text-sm text-slate-600 transition-colors hover:text-blue-600">About</a></li>
					<li><a href="/contact" class="text-sm text-slate-600 transition-colors hover:text-blue-600">Contact</a></li>
				</ul>
			</div>

			<div class="md:col-span-4">
				<p class="text-xs font-semibold uppercase tracking-wider text-slate-400">Connect</p>
				<ul class="mt-4 space-y-3">
					<li>
						<a
							href="mailto:soler2005david@gmail.com"
							class="text-sm text-slate-600 transition-colors hover:text-blue-600"
						>
							soler2005david@gmail.com
						</a>
					</li>
					<li>
						<a
							href="https://www.instagram.com/_soler.666/"
							target="_blank"
							rel="noopener noreferrer"
							class="text-sm text-slate-600 transition-colors hover:text-blue-600"
						>
							@_soler.666 on Instagram
						</a>
					</li>
				</ul>
			</div>
		</div>

		<div class="mt-10 flex flex-col items-start justify-between gap-4 border-t border-slate-100 pt-8 sm:flex-row sm:items-center">
			<p class="text-xs text-slate-400">
				&copy; {today.getFullYear()} {SITE_TITLE}. All rights reserved.
			</p>
			<p class="text-xs text-slate-400">Built with Astro & Tailwind CSS</p>
		</div>
	</div>
</footer>
