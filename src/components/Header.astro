---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="fixed top-0 left-0 z-50 w-full">
	<div
		class="w-full border-b border-transparent bg-white/80 backdrop-blur-md transition-[background-color,border-color] duration-300"
		data-header
	>
		<div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
			<a href="/" class="group inline-flex items-center gap-2.5" aria-label={`${SITE_TITLE} home`}>
				<span class="flex h-8 w-8 items-center justify-center rounded-lg bg-blue-600 text-xs font-bold text-white shadow-sm">
					NG
				</span>
				<span class="text-sm font-semibold tracking-tight text-slate-900 transition-colors group-hover:text-blue-600 md:text-base">
					{SITE_TITLE}
				</span>
			</a>

			<nav class="hidden items-center gap-8 md:flex" aria-label="Main navigation">
				<HeaderLink href="/" class="nav-link">Home</HeaderLink>
				<HeaderLink href="/blog" class="nav-link">Blog</HeaderLink>
				<HeaderLink href="/about" class="nav-link">About</HeaderLink>
				<HeaderLink href="/contact" class="nav-link">Contact</HeaderLink>
			</nav>

			<a
				href="/blog"
				class="inline-flex h-9 items-center justify-center rounded-lg bg-blue-600 px-4 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-blue-700"
			>
				Read articles
			</a>
		</div>
	</div>

	<script is:inline>
		const el = document.querySelector('[data-header]');
		if (el) {
			const apply = () => {
				const scrolled = window.scrollY > 8;
				el.style.backgroundColor = scrolled ? 'rgba(255,255,255,0.95)' : 'rgba(255,255,255,0.80)';
				el.style.borderColor = scrolled ? 'rgba(226,232,240,1)' : 'transparent';
			};
			apply();
			window.addEventListener('scroll', apply, { passive: true });
		}
	</script>
</header>

<style>
	:global(a.nav-link) {
		@apply text-sm font-medium text-slate-600 transition-colors hover:text-slate-900;
	}
	:global(a.nav-link.active) {
		@apply font-semibold text-blue-600;
	}
</style>
