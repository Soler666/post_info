---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="fixed top-0 left-0 w-full z-50">
	<div
		class="w-full border-b border-white/0 bg-transparent backdrop-blur-0 transition-[background-color,border-color,backdrop-filter] duration-300"
		data-header
	>
		<div class="mx-auto max-w-7xl px-6 h-16 flex items-center justify-between">
			<a href="/" class="group inline-flex items-center gap-2" aria-label={`${SITE_TITLE} Home`}>
				<span class="h-2.5 w-2.5 rounded-full bg-gradient-to-b from-cyan-400 to-blue-500 shadow-[0_0_20px_rgba(34,211,238,0.35)]" />
				<span class="text-sm md:text-base font-medium tracking-tighter text-white/95 group-hover:text-white transition-colors">
					{SITE_TITLE}
				</span>
			</a>

			<nav class="hidden md:flex items-center gap-7">
				<HeaderLink href="/">Home</HeaderLink>
				<HeaderLink href="/blog">Blog</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
			</nav>

			<div class="flex items-center gap-3">
				<a
					href="#"
					class="hidden sm:inline-flex items-center justify-center px-4 h-10 rounded-full border border-white/15 bg-white/5 text-white/90 hover:text-white transition-colors backdrop-blur-md"
					aria-label="Explore"
				>
					<span class="text-sm font-medium">Explore</span>
				</a>

				<a
					href="#"
					class="inline-flex items-center justify-center relative h-10 px-5 rounded-full text-sm font-semibold tracking-tight text-white overflow-hidden group"
					aria-label="Get Started"
				>
					<span
						class="absolute inset-0 bg-gradient-to-r from-cyan-400/30 via-indigo-400/30 to-purple-400/30 opacity-0 group-hover:opacity-100 transition-opacity"
					/>
					<span
						class="absolute inset-[1px] rounded-full bg-black/70 group-hover:bg-black/55 transition-colors"
					/>
					<span class="relative z-10">Get Started</span>
					<span
						class="absolute -inset-6 opacity-0 group-hover:opacity-100 transition-opacity rounded-full blur-[18px] bg-gradient-to-r from-cyan-400/40 via-indigo-400/40 to-purple-400/40"
					/>
				</a>
			</div>
		</div>
	</div>

	<script is:inline>
		const el = document.querySelector('[data-header]');
		if (el) {
			const apply = () => {
				const scrolled = window.scrollY > 8;
				el.style.backgroundColor = scrolled ? 'rgba(0,0,0,0.50)' : 'transparent';
				el.style.borderColor = scrolled ? 'rgba(255,255,255,0.10)' : 'rgba(255,255,255,0)';
				el.style.backdropFilter = scrolled ? 'blur(12px)' : 'blur(0px)';
			};
			apply();
			window.addEventListener('scroll', apply, { passive: true });
		}
	</script>
</header>
