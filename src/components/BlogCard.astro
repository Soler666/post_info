---
import type { CollectionEntry } from 'astro:content';

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { heroImage, title, description, pubDate } = post.data;

function formatDate(date: Date | string): string {
	const normalized = typeof date === 'string' ? new Date(date) : date;

	if (!(normalized instanceof Date) || Number.isNaN(normalized.getTime())) {
		return '';
	}

	return normalized.toLocaleDateString('en-US', {
		day: 'numeric',
		month: 'long',
		year: 'numeric',
	});
}

function getImageSrc(image: unknown): string {
	const fallback =
		'https://images.unsplash.com/photo-1518770660439-4636190af475?w=800&h=450&fit=crop';

	if (!image) return fallback;
	if (typeof image === 'string') return image;
	if (typeof image === 'object' && image !== null && 'src' in image) {
		return String((image as { src: string }).src);
	}

	return fallback;
}

const imageSrc = getImageSrc(heroImage);
const formattedDate = formatDate(pubDate);
---

<article class="group flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:shadow-md">
	<a href={`/blog/${post.id}/`} class="block overflow-hidden">
		<div class="aspect-[16/10] w-full overflow-hidden bg-slate-100">
			<img
				src={imageSrc}
				alt={`Cover: ${title}`}
				loading="lazy"
				width="400"
				height="250"
				class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
			/>
		</div>
	</a>

	<div class="flex flex-1 flex-col p-6">
		<time datetime={new Date(pubDate).toISOString()} class="text-xs font-medium uppercase tracking-wide text-slate-400">
			{formattedDate}
		</time>

		<h2 class="mt-3 text-xl font-bold leading-snug tracking-tight text-slate-900">
			<a href={`/blog/${post.id}/`} class="transition-colors hover:text-blue-600">
				{title}
			</a>
		</h2>

		<p class="mt-3 flex-1 text-sm leading-relaxed text-slate-600 line-clamp-3">
			{description}
		</p>

		<div class="mt-5 border-t border-slate-100 pt-4">
			<a
				href={`/blog/${post.id}/`}
				class="inline-flex items-center gap-2 text-sm font-semibold text-blue-600 transition-colors hover:text-blue-700"
			>
				Read article
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M5 12h14" />
					<path d="m12 5 7 7-7 7" />
				</svg>
			</a>
		</div>
	</div>
</article>
