---
interface Props {
	date: Date | string;
}

const { date } = Astro.props;

const normalized = typeof date === 'string' ? new Date(date) : date;

const formatted =
	normalized instanceof Date && !Number.isNaN(normalized.getTime())
		? normalized.toLocaleDateString('en-US', {
				day: 'numeric',
				month: 'long',
				year: 'numeric',
			})
		: '';
---

<time datetime={normalized instanceof Date ? normalized.toISOString() : undefined}>
	{formatted}
</time>
