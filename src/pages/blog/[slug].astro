---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BlogPostLayout from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ data }) => !data.draft);

	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BlogPostLayout {...post.data}>
	<article class="prose lg:prose-xl mx-auto max-w-none prose-headings:text-slate-900 prose-p:text-slate-700 prose-a:text-blue-600 prose-strong:text-slate-900 prose-code:rounded-md prose-code:bg-slate-100 prose-code:px-1 prose-blockquote:border-l-4 prose-blockquote:border-blue-500/40 prose-blockquote:pl-4 prose-blockquote:italic">
		<Content />
	</article>
</BlogPostLayout>
