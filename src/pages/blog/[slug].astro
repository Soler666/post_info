---
import { ViewTransitions } from 'astro:transitions';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { Image } from 'astro:assets';

type Props = CollectionEntry<'blog'>;

type BlogEntryData = Props['data'];

export async function getStaticPaths() {
	const entries = await getCollection('blog');

	return entries.map((entry) => ({
		params: { slug: entry.slug },
	}));
}

const { title, description, pubDate, updatedDate, heroImage } = Astro.props as BlogEntryData;


---
<html lang="en" class="scroll-smooth bg-black antialiased">
	<head>
		<BaseHead title={title} description={description} />
		<ViewTransitions />
	</head>

	<body class="text-neutral-400 font-sans min-h-screen flex flex-col selection:bg-white selection:text-black relative overflow-x-hidden">
		<div class="fixed inset-0 z-0 pointer-events-none bg-[linear-gradient(to_right,#7dd3fc0f_1px,transparent_1px),linear-gradient(to_bottom,#a78bfa0f_1px,transparent_1px)] bg-[size:26px_26px]" />
		<Header />

		<main class="flex-grow w-full relative z-10 pt-24">
			<article class="mx-auto max-w-3xl px-6">
				<header class="text-center">
					<h1 class="text-4xl md:text-5xl font-bold tracking-tighter text-white leading-tight">
						{title}
					</h1>
					<div class="mt-4 text-sm text-neutral-400">
						<span>Publicado el <FormattedDate date={pubDate} /></span>
						{
							updatedDate && (
								<span class="italic">{' • '}Actualizado el <FormattedDate date={updatedDate} /></span>
							)
						}
					</div>
				</header>

				{heroImage && (
					<div class="mt-8 relative">
						<img
							src={heroImage as string}
							alt={`Cover image for ${title}`}
							loading="lazy"
							class="w-full h-auto rounded-2xl border border-white/10"
						/>
						<div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent rounded-2xl" />
					</div>
				)}

				<div class="w-full h-32 bg-neutral-900 border border-dashed border-neutral-700 flex items-center justify-center text-neutral-500 rounded-xl my-8">
					AdSense Placeholder
				</div>

				<div class="prose prose-invert prose-lg max-w-none prose-p:text-neutral-400 prose-headings:text-white prose-a:text-cyan-400 prose-a:no-underline hover:prose-a:underline prose-strong:text-white prose-code:bg-neutral-900 prose-code:text-cyan-300 prose-code:p-1 prose-code:rounded-md prose-blockquote:border-l-cyan-400">
					<slot />
				</div>
			</article>
		</main>

		<Footer />
	</body>
</html>

