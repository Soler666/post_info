---
import Layout from '../layouts/PageLayout.astro';
import { SITE_TITLE } from '../consts';
---

<Layout
	title={`Contact — ${SITE_TITLE}`}
	description="Get in touch with Soler — email, Instagram, and more."
>
	<section class="border-b border-slate-200 bg-white">
		<div class="mx-auto max-w-6xl px-6 py-16 text-center">
			<p class="text-xs font-semibold uppercase tracking-[0.24em] text-blue-600">Contact</p>
			<h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
				Let's connect
			</h1>
			<p class="mx-auto mt-5 max-w-xl text-lg text-slate-600">
				Questions, collaborations, or topic suggestions — I'd love to hear from you.
			</p>
		</div>
	</section>

	<section class="py-16">
		<div class="mx-auto max-w-6xl px-6">
			<div class="grid gap-8 lg:grid-cols-2">
				<!-- Profile card -->
				<div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
					<div class="flex items-center gap-4">
						<div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-blue-600 text-2xl font-bold text-white">
							S
						</div>
						<div>
							<h2 class="text-2xl font-bold text-slate-900">Soler</h2>
							<p class="text-sm text-slate-500">Creator & Editor — {SITE_TITLE}</p>
						</div>
					</div>
					<p class="mt-6 text-sm leading-relaxed text-slate-600">
						I'm the person behind {SITE_TITLE}. Reach out for partnerships, article ideas, or just to say hello.
						I typically respond within a few days.
					</p>
				</div>

				<!-- Contact methods -->
				<div class="space-y-4">
					<a
						href="mailto:soler2005david@gmail.com"
						class="group flex items-center gap-4 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition-all hover:-translate-y-0.5 hover:border-blue-200 hover:shadow-md"
					>
						<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-blue-50 text-blue-600">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<rect width="20" height="16" x="2" y="4" rx="2" />
								<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
							</svg>
						</div>
						<div>
							<p class="text-xs font-semibold uppercase tracking-wider text-slate-400">Email</p>
							<p class="mt-1 font-semibold text-slate-900 group-hover:text-blue-600">
								soler2005david@gmail.com
							</p>
						</div>
					</a>

					<a
						href="https://www.instagram.com/_soler.666/"
						target="_blank"
						rel="noopener noreferrer"
						class="group flex items-center gap-4 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition-all hover:-translate-y-0.5 hover:border-blue-200 hover:shadow-md"
					>
						<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-blue-50 text-blue-600">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<rect width="20" height="20" x="2" y="2" rx="5" ry="5" />
								<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
								<line x1="17.5" x2="17.51" y1="6.5" y2="6.5" />
							</svg>
						</div>
						<div>
							<p class="text-xs font-semibold uppercase tracking-wider text-slate-400">Instagram</p>
							<p class="mt-1 font-semibold text-slate-900 group-hover:text-blue-600">@_soler.666</p>
						</div>
					</a>
				</div>
			</div>
		</div>
	</section>
</Layout>
