---
import Layout from '../layouts/PageLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const featuredPost = posts[0];
const latestPosts = posts.slice(1, 7);

const featuredImageSrc = featuredPost
	? typeof featuredPost.data.heroImage === 'string'
		? featuredPost.data.heroImage
		: (featuredPost.data.heroImage as { src?: string } | undefined)?.src
	: undefined;
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<!-- Hero -->
	<section class="relative overflow-hidden border-b border-slate-200 bg-white">
		<div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(37,99,235,0.08),_transparent_60%)]"></div>
		<div class="relative mx-auto max-w-6xl px-6 py-24 text-center md:py-32">
			<p class="text-sm font-semibold uppercase tracking-widest text-blue-600">
				Next-Gen Tech Magazine
			</p>
			<h1 class="mx-auto mt-5 max-w-4xl text-4xl font-extrabold tracking-tight text-slate-900 sm:text-6xl">
				Technology, Hardware & Maker Culture
			</h1>
			<p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-slate-600">
				Clear, practical articles on applied technology — from resin 3D printing and AI workflows to the hardware that powers modern creators.
			</p>
			<div class="mt-10 flex flex-wrap items-center justify-center gap-4">
				<a
					href="/blog"
					class="inline-flex items-center justify-center rounded-lg bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-blue-700"
				>
					Browse articles
				</a>
				<a
					href="/about"
					class="inline-flex items-center justify-center rounded-lg border border-slate-200 bg-white px-6 py-3 text-sm font-semibold text-slate-700 shadow-sm transition-colors hover:border-slate-300 hover:bg-slate-50"
				>
					About us
				</a>
			</div>
		</div>
	</section>

	<!-- Featured -->
	{
		featuredPost && (
			<section class="py-16">
				<div class="mx-auto max-w-6xl px-6">
					<div class="mb-8 flex items-end justify-between">
						<h2 class="text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">Featured</h2>
						<a href="/blog" class="text-sm font-semibold text-blue-600 hover:text-blue-700">
							View all &rarr;
						</a>
					</div>
					<a
						href={`/blog/${featuredPost.id}/`}
						class="group block overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg"
					>
						<div class="grid grid-cols-1 lg:grid-cols-2">
							<div class="relative aspect-[16/10] lg:aspect-auto lg:min-h-[320px]">
								{featuredImageSrc && (
									<img
										src={featuredImageSrc}
										alt={`Cover for ${featuredPost.data.title}`}
										loading="lazy"
										class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
									/>
								)}
							</div>
							<div class="flex flex-col justify-center p-8 sm:p-12">
								<h3 class="text-2xl font-bold text-slate-900 sm:text-3xl">
									{featuredPost.data.title}
								</h3>
								<p class="mt-4 text-slate-600 line-clamp-4">{featuredPost.data.description}</p>
								<span class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-blue-600">
									Read full article
									<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M5 12h14" />
										<path d="m12 5 7 7-7 7" />
									</svg>
								</span>
							</div>
						</div>
					</a>
				</div>
			</section>
		)
	}

	<!-- Latest or empty state -->
	<section class="py-16">
		<div class="mx-auto max-w-6xl px-6">
			{
				latestPosts.length > 0 ? (
					<>
						<div class="mb-10 flex items-end justify-between">
							<div>
								<h2 class="text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">
									Latest articles
								</h2>
								<p class="mt-2 text-slate-600">Stay up to date with our newest research and analysis.</p>
							</div>
							<a href="/blog" class="hidden text-sm font-semibold text-blue-600 hover:text-blue-700 sm:block">
								View all &rarr;
							</a>
						</div>
						<div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
							{latestPosts.map((post) => (
								<BlogCard post={post} />
							))}
						</div>
					</>
				) : !featuredPost ? (
					<div class="rounded-2xl border border-dashed border-slate-300 bg-white p-12 text-center">
						<h2 class="text-xl font-bold text-slate-900">Fresh content coming soon</h2>
						<p class="mx-auto mt-3 max-w-md text-sm text-slate-600">
							We're preparing our first articles. In the meantime, feel free to reach out or follow us on Instagram.
						</p>
						<div class="mt-6 flex flex-wrap justify-center gap-3">
							<a href="/contact" class="rounded-lg bg-blue-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-blue-700">
								Contact us
							</a>
							<a
								href="https://www.instagram.com/_soler.666/"
								target="_blank"
								rel="noopener noreferrer"
								class="rounded-lg border border-slate-200 px-5 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50"
							>
								Follow on Instagram
							</a>
						</div>
					</div>
				) : null
			}
		</div>
	</section>

	<!-- CTA -->
	<section class="border-t border-slate-200 bg-white py-16">
		<div class="mx-auto max-w-6xl px-6">
			<div class="rounded-2xl bg-slate-900 px-8 py-12 text-center sm:px-16">
				<h2 class="text-2xl font-bold text-white sm:text-3xl">Want to collaborate or suggest a topic?</h2>
				<p class="mx-auto mt-4 max-w-xl text-slate-300">
					We'd love to hear from fellow makers, engineers, and tech enthusiasts.
				</p>
				<a
					href="/contact"
					class="mt-8 inline-flex items-center justify-center rounded-lg bg-white px-6 py-3 text-sm font-semibold text-slate-900 transition-colors hover:bg-slate-100"
				>
					Contact Soler
				</a>
			</div>
		</div>
	</section>
</Layout>

<style>
	.line-clamp-4 {
		overflow: hidden;
		display: -webkit-box;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 4;
	}
</style>
