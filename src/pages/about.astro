---
import Layout from '../layouts/PageLayout.astro';
import { SITE_TITLE } from '../consts';
---

<Layout
	title={`About ${SITE_TITLE}`}
	description={`Learn more about ${SITE_TITLE}, a premium content website for advanced resin 3D printing, AI workflows, and tech hardware.`}
>
	<h1 class="text-4xl md:text-5xl font-bold tracking-tighter text-white leading-tight">
		About Next-Gen Makers
	</h1>
	<p>
		<strong>Next-Gen Makers</strong> is a production-grade, highly optimized content website
		targeting the US market to monetize via Google AdSense. The niche is focused on "Next-Gen
		Makers" — advanced resin 3D printing, AI workflows for creators, and tech hardware.
	</p>

	<p>
		Our goal is to refactor the default Astro Blog template into a premium, hyper-modern, Silicon
		Valley-style web application (think Vercel, Linear, or Stripe design language).
	</p>
</Layout>
